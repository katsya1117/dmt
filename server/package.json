{
  "name": "manual-maintenance-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "tsoa": "tsoa spec-and-routes",
    "dev": "npm run tsoa && tsx watch src/index.ts",
    "build": "npm run tsoa && tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/generated',{recursive:true});fs.copyFileSync('src/generated/swagger.json','dist/generated/swagger.json')\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "form-data": "^4.0.6",
    "multer": "^2.2.0",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.0.1",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
