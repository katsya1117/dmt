{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Server (Express/tsx)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "--import", "tsx", "src/index.ts"],
      "cwd": "${workspaceFolder}/server",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "restart": true,
      "preLaunchTask": "server: generate tsoa routes"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Client (Chrome)",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/client",
      "preLaunchTask": "client: dev server"
    }
  ],
  "compounds": [
    {
      "name": "Full stack (Server + Client)",
      "configurations": ["Server (Express/tsx)", "Client (Chrome)"],
      "stopAll": true
    }
  ]
}
